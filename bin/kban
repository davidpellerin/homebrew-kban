#!/usr/bin/env bash
#
# kban - Simple filesystem-based kanban board for Claude Code agents
#
# Usage: kban <command> [arguments]
#

set -euo pipefail

# =============================================================================
# Colors and Logging
# =============================================================================

if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
    readonly RED='\033[0;31m'
    readonly GREEN='\033[0;32m'
    readonly YELLOW='\033[0;33m'
    readonly BLUE='\033[0;34m'
    readonly NC='\033[0m'
else
    readonly RED=''
    readonly GREEN=''
    readonly YELLOW=''
    readonly BLUE=''
    readonly NC=''
fi

die()         { echo -e "${RED}[ERROR]${NC} $1" >&2; exit "${2:-1}"; }
log_info()    { echo -e "${BLUE}[INFO]${NC} $1" >&2; }
log_success() { echo -e "${GREEN}[OK]${NC} $1" >&2; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC} $1" >&2; }

# =============================================================================
# Config
# =============================================================================

# shellcheck disable=SC2310  # deps_met/find_ticket return values are handled correctly
readonly KBAN_VERSION="1.12.0"
readonly KBAN_DIR="${PWD}/.kban/work"
readonly LANES=(backlog ready doing "done")
readonly ARCHIVE_LANE="archive"
readonly COL_WIDTH=22
TEMPLATES_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../templates"
readonly TEMPLATES_DIR

# =============================================================================
# Usage
# =============================================================================

usage() {
    cat <<EOF
kban - Simple filesystem-based kanban board

Usage: kban <command> [arguments]

Commands:
    version                     Show kban version
    init                        Create .kban folder structure in current directory
    install skill user          Install Claude Code skill for your user account (all projects)
    install skill project       Install Claude Code skill for this project only
    board                       Show the board overview
    create <id>                 Create a new ticket (default lane: backlog)
    list [lane]                 List tickets in a lane (or all lanes)
    show <id>                   Show ticket details
    next                        Show the next actionable ticket (ready + deps met)
    start <id>                  Move ticket to doing
    done <id>                   Mark ticket as done
    promote                     Move eligible backlog tickets to ready
    move <id> <lane>            Move ticket to any lane
    block <id>                  Mark ticket as blocked
    unblock <id>                Clear blocked status from ticket
    archive <id>                Move ticket to archive (hidden from board)
    unarchive <id>              Restore ticket from archive to done
    tickets [lane]              Flat list of all tickets with lane/priority/deps
    delete <id>                 Delete a ticket permanently
    serve                       Start the web UI (default: http://localhost:8080)
    work [--prompt <file>]      Run claude on every ready ticket

Options for create:
    --title "..."               Ticket title (required)
    --priority high|medium|low  Priority (default: medium)
    --lane <lane>               Lane to create in (default: backlog)
    --depends-on ID1,ID2        Comma-separated dependency IDs

Lanes: backlog, ready, doing, done, archive

Environment variables for serve:
    KBAN_HOST           Host to bind (default: localhost)
    KBAN_PORT           Port to bind (default: 8080)

EOF
}

# =============================================================================
# Frontmatter helpers
# =============================================================================

# Extract a single field value from YAML frontmatter
# Arguments:
#   $1 - file path
#   $2 - field name
# Outputs:
#   Field value to stdout
get_field() {
    local file="${1}"
    local field="${2}"
    awk 'BEGIN{fm=0} /^---$/{fm++; next} fm==1{print}' "${file}" \
        | grep "^${field}:" \
        | head -1 \
        | sed "s/^${field}: *//"
}

# Output dependency ids, one per line
# Arguments:
#   $1 - file path
# Outputs:
#   One dep id per line, or nothing if no deps
get_deps() {
    local file="${1}"
    local raw
    raw="$(get_field "${file}" "depends_on")"
    [[ -z "${raw}" || "${raw}" == "[]" ]] && return 0
    # Strip brackets, split on commas, trim whitespace
    echo "${raw}" | tr -d '[]' | tr ',' '\n' | sed 's/^ *//;s/ *$//' | grep -v '^$'
}

# =============================================================================
# Ticket lookup
# =============================================================================

# Find a ticket file by id (searches all lanes)
# Arguments:
#   $1 - ticket id
# Outputs:
#   Full path to ticket file
# Returns:
#   0 if found, 1 otherwise
find_ticket() {
    local id="${1}"
    local lane
    for lane in "${LANES[@]}" "${ARCHIVE_LANE}"; do
        local path="${KBAN_DIR}/${lane}/${id}.md"
        if [[ -f "${path}" ]]; then
            echo "${path}"
            return 0
        fi
    done
    return 1
}

# Get the lane name for a ticket
# Arguments:
#   $1 - ticket id
# Outputs:
#   Lane name
get_lane() {
    local id="${1}"
    local path
    path="$(find_ticket "${id}")"
    basename "$(dirname "${path}")"
}

# Check if all dependencies for a ticket are in done
# Arguments:
#   $1 - file path
# Returns:
#   0 if all deps met (or no deps), 1 otherwise
deps_met() {
    local file="${1}"
    local dep
    # shellcheck disable=SC2312
    while IFS= read -r dep; do
        [[ -z "${dep}" ]] && continue
        [[ -f "${KBAN_DIR}/done/${dep}.md" ]] || return 1
    done < <(get_deps "${file}")
    return 0
}

# =============================================================================
# Commands
# =============================================================================

cmd_version() {
    echo "kban ${KBAN_VERSION}"
}

# Initialize the .kban folder structure in the current directory
sample_ticket() {
    cat "${TEMPLATES_DIR}/sample-tickets/sample-ticket.md"
}

cmd_init() {
    if [[ -d "${KBAN_DIR}" ]]; then
        log_warn ".kban already exists at ${KBAN_DIR}"
        return 0
    fi

    local lane
    for lane in "${LANES[@]}" "${ARCHIVE_LANE}"; do
        mkdir -p "${KBAN_DIR}/${lane}"
        touch "${KBAN_DIR}/${lane}/.gitkeep"
    done

    # Create a sample backlog ticket
    sample_ticket > "${KBAN_DIR}/backlog/SETUP-001.md"

    log_success "Initialized .kban board at ${KBAN_DIR}"
    log_info "Sample ticket created: SETUP-001 (backlog)"
    log_info "Run 'kban board' to see your board"
}

# Display the kanban board
cmd_board() {
    local sep
    sep="$(printf '%*s' "${COL_WIDTH}" '' | tr ' ' '─')"

    echo ""

    # Header row
    local header=""
    local lane cnt label
    for lane in "${LANES[@]}"; do
        # shellcheck disable=SC2312
        cnt=$(find "${KBAN_DIR}/${lane}" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
        label="$(echo "${lane}" | tr '[:lower:]' '[:upper:]') (${cnt})"
        header="${header}$(printf "%-${COL_WIDTH}s  " "${label}")"
    done
    # shellcheck disable=SC2154
    echo -e "${BLUE}${header}${NC}"

    # Separator row
    local sep_row=""
    for lane in "${LANES[@]}"; do
        sep_row="${sep_row}${sep}  "
    done
    echo "${sep_row}"

    # Find max ticket count across lanes
    local max=0
    for lane in "${LANES[@]}"; do
        # shellcheck disable=SC2312
        cnt=$(find "${KBAN_DIR}/${lane}" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
        [[ "${cnt}" -gt "${max}" ]] && max="${cnt}"
    done

    # Print one row per ticket slot
    local i row ticket file
    for ((i=1; i<=max; i++)); do
        row=""
        for lane in "${LANES[@]}"; do
            # shellcheck disable=SC2312
            file=$(find "${KBAN_DIR}/${lane}" -name "*.md" 2>/dev/null | sort | sed -n "${i}p")
            if [[ -n "${file}" ]]; then
                ticket=$(basename "${file}" .md)
            else
                ticket=""
            fi
            row="${row}$(printf "%-${COL_WIDTH}s  " "${ticket}")"
        done
        echo "${row}"
    done
    echo ""
}

# List tickets in one or all lanes
# Arguments:
#   $1 - lane name, or "all" (default)
cmd_list() {
    local lane="${1:-all}"
    local lane_name
    if [[ "${lane}" == "all" ]]; then
        for lane_name in "${LANES[@]}"; do
            local has_tickets=false
            # shellcheck disable=SC2312
            while IFS= read -r f; do
                if [[ "${has_tickets}" == "false" ]]; then
                    # shellcheck disable=SC2154
                    echo -e "${YELLOW}[${lane_name}]${NC}"
                    has_tickets=true
                fi
                local tid blocked_val suffix
                tid="$(basename "${f}" .md)"
                blocked_val="$(get_field "${f}" "blocked")" || blocked_val="" || blocked_val=""
                suffix=""
                [[ "$(echo "${blocked_val}" | tr '[:upper:]' '[:lower:]')" == "true" ]] && suffix=" ${RED}[BLOCKED]${NC}"
                echo -e "${tid}${suffix}"
            done < <(find "${KBAN_DIR}/${lane_name}" -name "*.md" 2>/dev/null | sort)
        done
    else
        # shellcheck disable=SC2312
        while IFS= read -r f; do
            local tid blocked_val suffix
            tid="$(basename "${f}" .md)"
            blocked_val="$(get_field "${f}" "blocked")" || blocked_val=""
            suffix=""
            [[ "$(echo "${blocked_val}" | tr '[:upper:]' '[:lower:]')" == "true" ]] && suffix=" ${RED}[BLOCKED]${NC}"
            echo -e "${tid}${suffix}"
        done < <(find "${KBAN_DIR}/${lane}" -name "*.md" 2>/dev/null | sort)
    fi
}

# Flat list view of all tickets (or filtered by lane)
# Arguments:
#   $1 - lane name (optional, default: all lanes)
cmd_tickets() {
    local filter_lane="${1:-}"
    local lanes_to_show=()

    if [[ -n "${filter_lane}" ]]; then
        local valid=false
        local l
        for l in "${LANES[@]}"; do
            [[ "${l}" == "${filter_lane}" ]] && valid=true
        done
        [[ "${valid}" == "false" ]] && die "Invalid lane: ${filter_lane}. Valid: ${LANES[*]}"
        lanes_to_show=("${filter_lane}")
    else
        lanes_to_show=("${LANES[@]}")
    fi

    # Column widths
    local id_w=14 lane_w=9 prio_w=8

    # shellcheck disable=SC2154
    printf "${BLUE}%-${id_w}s  %-${lane_w}s  %-${prio_w}s  %s${NC}\n" "ID" "LANE" "PRIORITY" "TITLE"
    printf '%s\n' "$(printf '%.0s─' {1..70})"

    local lane f tid title priority deps blocked_val row_suffix
    for lane in "${lanes_to_show[@]}"; do
        # shellcheck disable=SC2312
        while IFS= read -r f; do
            tid="$(basename "${f}" .md)"
            title="$(get_field "${f}" "title")"
            priority="$(get_field "${f}" "priority")"
            deps="$(get_field "${f}" "depends_on")"
            blocked_val="$(get_field "${f}" "blocked")" || blocked_val=""

            row_suffix=""
            [[ -n "${deps}" && "${deps}" != "[]" ]] && row_suffix=" ${BLUE}[deps: ${deps}]${NC}"
            [[ "$(echo "${blocked_val}" | tr '[:upper:]' '[:lower:]')" == "true" ]] && row_suffix=" ${RED}[BLOCKED]${NC}"

            printf "%-${id_w}s  %-${lane_w}s  %-${prio_w}s  %s" \
                "${tid}" "${lane}" "${priority:-medium}" "${title:-${tid}}"
            echo -e "${row_suffix}"
        done < <(find "${KBAN_DIR}/${lane}" -name "*.md" 2>/dev/null | sort)
    done
}

# Show ticket details
# Arguments:
#   $1 - ticket id
cmd_show() {
    [[ $# -eq 0 ]] && die "Usage: kban show <id>"
    local id="${1}"
    local path
    # shellcheck disable=SC2310
    if ! path="$(find_ticket "${id}")"; then
        die "Ticket not found: ${id}"
    fi
    local lane
    lane="$(get_lane "${id}")"

    # shellcheck disable=SC2154
    echo -e "${BLUE}[${lane}]${NC} ${id}"
    echo "─────────────────────────────────────"
    cat "${path}"
}

# Output the id of the next actionable ticket (in ready, deps met)
cmd_next() {
    local found=false
    local f
    # shellcheck disable=SC2312
    while IFS= read -r f; do
        # shellcheck disable=SC2310
        if deps_met "${f}"; then
            basename "${f}" .md
            found=true
            break
        fi
    done < <(find "${KBAN_DIR}/ready" -name "*.md" 2>/dev/null | sort)

    if [[ "${found}" == "false" ]]; then
        log_warn "No actionable tickets in ready"
        return 1
    fi
}

# Warn if ticket ID does not match the canonical format (UPPER-digits)
# Arguments:
#   $1 - ticket id
validate_ticket_id() {
    local id="${1}"
    if ! [[ "${id}" =~ ^[A-Z]+-[0-9]+$ ]]; then
        log_warn "Ticket ID '${id}' does not match canonical format (e.g. TASK-001, FEAT-042). The web UI will reject non-canonical IDs."
    fi
}

# Create a new ticket
# Arguments:
#   $1 - ticket id
#   Options: --title, --priority, --lane, --depends-on
cmd_create() {
    [[ $# -eq 0 ]] && die "Usage: kban create <id> --title \"...\" [--priority high|medium|low] [--lane backlog|ready|doing|done] [--depends-on ID1,ID2]"
    local id="${1}"
    shift

    validate_ticket_id "${id}"

    local title="" priority="medium" lane="backlog" depends_on=""

    while [[ $# -gt 0 ]]; do
        case "${1}" in
            --title)      title="${2}"; shift 2 ;;
            --priority)   priority="${2}"; shift 2 ;;
            --lane)       lane="${2}"; shift 2 ;;
            --depends-on) depends_on="${2}"; shift 2 ;;
            *) die "Unknown option: ${1}" ;;
        esac
    done

    [[ -z "${title}" ]] && die "--title is required"

    # Validate priority
    case "${priority}" in
        high|medium|low) ;;
        *) die "Invalid priority: ${priority}. Valid: high, medium, low" ;;
    esac

    # Validate lane
    local valid_lane=false
    local l
    for l in "${LANES[@]}"; do
        [[ "${l}" == "${lane}" ]] && valid_lane=true
    done
    [[ "${valid_lane}" == "false" ]] && die "Invalid lane: ${lane}. Valid: ${LANES[*]}"

    # Check ticket doesn't already exist
    local existing
    # shellcheck disable=SC2310
    if existing="$(find_ticket "${id}" 2>/dev/null)"; then
        die "Ticket already exists: ${id} (in $(basename "$(dirname "${existing}")"))"
    fi

    # Build depends_on YAML value
    local deps_yaml="[]"
    if [[ -n "${depends_on}" ]]; then
        # Convert comma-separated to YAML list: [ID1, ID2]
        deps_yaml="[${depends_on//,/, }]"
    fi

    local dest="${KBAN_DIR}/${lane}/${id}.md"
    cat > "${dest}" <<EOF
---
title: ${title}
priority: ${priority}
depends_on: ${deps_yaml}
---

## Goal

${title}

## Tasks

- [ ] TODO
EOF

    log_success "Created ${id} in ${lane}: ${title}"
}

# Move a ticket to a lane
# Arguments:
#   $1 - ticket id
#   $2 - target lane
cmd_move() {
    [[ $# -lt 2 ]] && die "Usage: kban move <id> <lane>"
    local id="${1}"
    local target="${2}"
    validate_ticket_id "${id}"

    local valid=false
    local lane
    for lane in "${LANES[@]}" "${ARCHIVE_LANE}"; do
        [[ "${lane}" == "${target}" ]] && valid=true
    done
    [[ "${valid}" == "false" ]] && die "Invalid lane: ${target}. Valid: ${LANES[*]} ${ARCHIVE_LANE}"

    local path
    # shellcheck disable=SC2310
    if ! path="$(find_ticket "${id}")"; then
        die "Ticket not found: ${id}"
    fi
    local current
    current="$(get_lane "${id}")"

    if [[ "${current}" == "${target}" ]]; then
        log_warn "${id} is already in ${target}"
        return 0
    fi

    mv "${path}" "${KBAN_DIR}/${target}/${id}.md"
    log_success "${id}: ${current} → ${target}"
}

# Set or clear the blocked field in a ticket's frontmatter
# Arguments:
#   $1 - ticket file path
#   $2 - "true" to block, "false" to unblock
_set_blocked() {
    local file="${1}"
    local value="${2}"
    local tmp
    tmp="$(mktemp)"

    if [[ "${value}" == "true" ]]; then
        # Add or update `blocked: true` inside the frontmatter
        awk '
            BEGIN { fm=0; done=0 }
            /^---$/ && fm==0 { fm=1; print; next }
            /^---$/ && fm==1 {
                if (!done) { print "blocked: true"; done=1 }
                fm=2; print; next
            }
            fm==1 && /^blocked:/ { print "blocked: true"; done=1; next }
            { print }
        ' "${file}" > "${tmp}"
    else
        # Remove `blocked:` line from frontmatter
        awk '
            BEGIN { fm=0 }
            /^---$/ && fm==0 { fm=1; print; next }
            /^---$/ && fm==1 { fm=2; print; next }
            fm==1 && /^blocked:/ { next }
            { print }
        ' "${file}" > "${tmp}"
    fi
    mv "${tmp}" "${file}"
}

# Mark a ticket as blocked
# Arguments:
#   $1 - ticket id
cmd_block() {
    [[ $# -eq 0 ]] && die "Usage: kban block <id>"
    local id="${1}"
    local path
    # shellcheck disable=SC2310
    if ! path="$(find_ticket "${id}")"; then
        die "Ticket not found: ${id}"
    fi
    _set_blocked "${path}" "true"
    log_success "${id} marked as blocked"
}

# Clear blocked status from a ticket
# Arguments:
#   $1 - ticket id
cmd_unblock() {
    [[ $# -eq 0 ]] && die "Usage: kban unblock <id>"
    local id="${1}"
    local path
    # shellcheck disable=SC2310
    if ! path="$(find_ticket "${id}")"; then
        die "Ticket not found: ${id}"
    fi
    _set_blocked "${path}" "false"
    log_success "${id} unblocked"
}

# Promote eligible backlog tickets to ready
# A ticket is eligible if all its deps are met and it is not blocked
cmd_promote() {
    local promoted=0
    local f bid blocked_val
    # shellcheck disable=SC2312
    while IFS= read -r f; do
        bid="$(basename "${f}" .md)"
        blocked_val="$(get_field "${f}" "blocked")" || blocked_val=""
        # shellcheck disable=SC2310
        if deps_met "${f}" && [[ "$(echo "${blocked_val}" | tr '[:upper:]' '[:lower:]')" != "true" ]]; then
            mv "${f}" "${KBAN_DIR}/ready/${bid}.md"
            log_success "${bid}: backlog → ready"
            ((promoted++)) || true
        fi
    done < <(find "${KBAN_DIR}/backlog" -name "*.md" 2>/dev/null | sort)

    if [[ "${promoted}" -eq 0 ]]; then
        log_warn "No eligible tickets to promote"
    fi
}

# Move ticket to archive (hidden from board)
# Arguments:
#   $1 - ticket id
cmd_archive() {
    [[ $# -eq 0 ]] && die "Usage: kban archive <id>"
    local id="${1}"
    local path
    # shellcheck disable=SC2310
    if ! path="$(find_ticket "${id}")"; then
        die "Ticket not found: ${id}"
    fi
    local current
    current="$(basename "$(dirname "${path}")")"
    if [[ "${current}" == "${ARCHIVE_LANE}" ]]; then
        log_warn "${id} is already archived"
        return 0
    fi
    mv "${path}" "${KBAN_DIR}/${ARCHIVE_LANE}/${id}.md"
    log_success "${id}: ${current} → archive"
}

# Restore ticket from archive to done
# Arguments:
#   $1 - ticket id
cmd_unarchive() {
    [[ $# -eq 0 ]] && die "Usage: kban unarchive <id>"
    local id="${1}"
    local path="${KBAN_DIR}/${ARCHIVE_LANE}/${id}.md"
    if [[ ! -f "${path}" ]]; then
        die "Ticket not found in archive: ${id}"
    fi
    mv "${path}" "${KBAN_DIR}/done/${id}.md"
    log_success "${id}: archive → done"
}

# Move ticket to doing
# Arguments:
#   $1 - ticket id
cmd_start() {
    [[ $# -eq 0 ]] && die "Usage: kban start <id>"
    cmd_move "${1}" "doing"
}

# Move ticket to done (with auto-promote)
# Arguments:
#   $1 - ticket id
cmd_done() {
    [[ $# -eq 0 ]] && die "Usage: kban done <id>"
    cmd_move "${1}" "done"
}

# Install an agent or skill for the current project
# Arguments:
#   $1 - type (agent, skill)
#   $2 - tool name (claude, opencode)
cmd_install() {
    [[ $# -eq 0 ]] && die "Usage: kban install <agent|skill> <tool>"
    local type="${1}"
    shift

    case "${type}" in
        skill) cmd_install_skill "$@" ;;
        *) die "Unknown install type: ${type}. Supported: skill" ;;
    esac
}

# Install a Claude Code skill for the current project
# Arguments:
#   $1 - tool name (claude)
#   $2 - scope (user|project)
cmd_install_skill() {
    [[ $# -eq 0 ]] && die "Usage: kban install skill user|project"
    local tool="${1}"
    shift

    case "${tool}" in
        claude) cmd_install_skill_claude "$@" ;;
        *) die "Unknown tool: ${tool}. Supported: claude" ;;
    esac
}

cmd_install_skill_claude() {
    local scope="${1:-}"

    # Prompt if scope not specified
    if [[ -z "${scope}" ]]; then
        echo "Where do you want to install the kban skill?"
        echo "  [1] user     → ${HOME}/.claude/skills/kban/ (available in all projects)"
        echo "  [2] project  → ./.claude/skills/kban/ (this project only)"
        printf "Choose [1/2]: "
        local choice
        read -r choice
        case "${choice}" in
            1|user)    scope="user" ;;
            2|project) scope="project" ;;
            *) die "Invalid choice: ${choice}. Enter 1 or 2." ;;
        esac
    fi

    local dest_dir
    case "${scope}" in
        user)    dest_dir="${HOME}/.claude/skills/kban" ;;
        project) dest_dir=".claude/skills/kban" ;;
        *) die "Invalid scope: ${scope}. Use 'user' or 'project'." ;;
    esac

    local dest="${dest_dir}/SKILL.md"
    if [[ -f "${dest}" ]]; then
        log_warn "${dest} already exists — skipping"
        return 0
    fi
    mkdir -p "${dest_dir}"
    cat "${TEMPLATES_DIR}/skills/kban/SKILL.md" > "${dest}"
    log_success "Installed kban skill → ${dest}"
    log_info "Run 'kban init' first if you haven't set up the board yet"
}

# Delete a ticket permanently
# Arguments:
#   $1 - ticket id
cmd_delete() {
    [[ $# -eq 0 ]] && die "Usage: kban delete <id>"
    local id="${1}"
    local path
    # shellcheck disable=SC2310
    if ! path="$(find_ticket "${id}")"; then
        die "Ticket not found: ${id}"
    fi
    local lane
    lane="$(basename "$(dirname "${path}")")"
    rm "${path}"
    log_success "Deleted ${id} (was in ${lane})"
}

# Run claude against every ready ticket
# Options:
#   --prompt <path>   Path to agent prompt file (default: TEMPLATES_DIR/agent-prompt.md)
cmd_work() {
    local prompt_file="${TEMPLATES_DIR}/agent-prompt.md"

    while [[ $# -gt 0 ]]; do
        case "${1}" in
            --prompt) prompt_file="${2}"; shift 2 ;;
            *) die "Unknown option: ${1}" ;;
        esac
    done

    [[ -f "${prompt_file}" ]] || die "Prompt file not found: ${prompt_file}"

    local f id
    # shellcheck disable=SC2312
    while IFS= read -r f; do
        id="$(basename "${f}" .md)"
        log_info "Working on ${id}"
        cmd_start "${id}" || continue
        { cat "${prompt_file}"; kban show "${id}"; } | claude --dangerously-skip-permissions --print
    done < <(find "${KBAN_DIR}/ready" -name "*.md" 2>/dev/null | sort)
}

# Start the web UI
cmd_serve() {
    local script
    script="$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../web/serve.py"
    if [[ ! -f "${script}" ]]; then
        die "Web server script not found: ${script}"
    fi
    exec python3 "${script}"
}

# =============================================================================
# Main
# =============================================================================

main() {
    [[ $# -eq 0 ]] && { usage; exit 0; }

    local cmd="${1}"
    shift

    case "${cmd}" in
        version)   cmd_version ;;
        init)      cmd_init ;;
        install)   cmd_install "$@" ;;
        board)     cmd_board ;;
        create)    cmd_create "$@" ;;
        list)      cmd_list "$@" ;;
        show)      cmd_show "$@" ;;
        next)      cmd_next ;;
        start)     cmd_start "$@" ;;
        "done")    cmd_done "$@" ;;
        move)      cmd_move "$@" ;;
        promote)   cmd_promote ;;
        block)     cmd_block "$@" ;;
        unblock)   cmd_unblock "$@" ;;
        archive)   cmd_archive "$@" ;;
        unarchive) cmd_unarchive "$@" ;;
        tickets)   cmd_tickets "$@" ;;
        delete)    cmd_delete "$@" ;;
        serve)     cmd_serve ;;
        work)      cmd_work "$@" ;;
        -h|--help) usage ;;
        *) die "Unknown command: ${cmd}. Use 'kban --help' for usage." ;;
    esac
}

main "$@"
